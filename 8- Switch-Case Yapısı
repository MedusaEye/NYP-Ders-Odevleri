            // SORU: Girilen sayiya kadar olan asal sayilari listeleyen program
            Console.WriteLine("Bir sayı giriniz:");
            int sinirDegeri = Convert.ToInt32(Console.ReadLine());

            // 2'den başlayarak girilen sayıya kadar tüm sayıları tek tek dolaşıyoruz
            for (int sayi = 2; sayi <= sinirDegeri; sayi++)
            {
                bool asalMi = true; // Başlangıçta her sayıyı asal kabul ediyoruz
                
                // Sayıyı, 2'den başlayıp kendisinden bir önceki sayıya kadar bölmeye çalışıyoruz
                for (int bolen = 2; bolen < sayi; bolen++)
                {
                    if (sayi % bolen == 0)
                    {
                        asalMi = false; // Kalansız bölündüyse asal değildir
                        break; // Asal olmadığı anlaşıldığı için daha fazla bölmeye gerek yok, döngüden çık
                    }
                }

                // Eğer yukarıdaki testten asalMi değeri hala true olarak çıktıysa ekrana yazdır
                if (asalMi)
                {
                    Console.WriteLine($"{sayi} Sayısı asaldır");
                }
            }

            Console.ReadKey();
        }
