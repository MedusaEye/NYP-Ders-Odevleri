using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApp1
{
    internal class Program
    {
        //SORU: İki sayının ortalamasını return ile döndüren metot yazın.
        static double OrtalamaBul(double sayi1, double sayi2)
        {
            return (sayi1 + sayi2) / 2;
        }

        static void Main(string[] args)
        {
            double birinciSayi, ikinciSayi, sonuc;

            Console.Write("1. Sayıyı Giriniz: ");
            birinciSayi = Convert.ToDouble(Console.ReadLine());

            Console.Write("2. Sayıyı Giriniz: ");
            ikinciSayi = Convert.ToDouble(Console.ReadLine());

            sonuc = OrtalamaBul(birinciSayi, ikinciSayi);
            
            Console.WriteLine("Ortalama: " + sonuc);

            Console.ReadKey();
        }
    }
}
